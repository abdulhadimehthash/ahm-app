{
  "expo": {
    "name": "AHM",
    "slug": "ahm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ahm.mobile",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "AHM sends local reminders for tasks due today or tomorrow."
      }
    },
    "android": {
      "package": "com.ahm.mobile",
      "useNextNotificationsApi": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "AHM needs access to your photos to save documents.",
          "cameraPermission": "AHM needs access to your camera to take document photos."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "AHM needs access to your contacts to import them as a backup."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "supabaseUrl": "https://titiljrgqynroxpaznkq.supabase.co",
      "supabasePublishableKey": "sb_publishable_oYTGDsHQOvboNc48dRfJTQ_0RqwlP7l",
      "eas": {
        "projectId": "885a4469-3fe9-4a64-bfec-5f7bf549ab50"
      }
    },
    "owner": "hadimehthash"
  }
}
