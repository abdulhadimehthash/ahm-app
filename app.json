{
  "expo": {
    "name": "AHM",
    "slug": "ahm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ahm.mobile",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "AHM sends local reminders for tasks due today or tomorrow."
      }
    },
    "android": {
      "package": "com.ahm.mobile",
      "minSdkVersion": 21,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_CONTACTS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "AHM needs access to your photos to save documents.",
          "cameraPermission": "AHM needs access to your camera to take document photos."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "AHM needs access to your contacts to import them as a backup."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TaskWidget",
              "label": "AHM Tasks",
              "description": "Shows your most urgent task",
              "minWidth": "250dp",
              "minHeight": "40dp",
              "targetCellWidth": 4,
              "targetCellHeight": 1,
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/icon.png"
            }
          ]
        }
      ],
      "./plugins/withAbiFilters",
      "expo-font"
    ],
    "extra": {
      "supabaseUrl": "https://titiljrgqynroxpaznkq.supabase.co",
      "supabasePublishableKey": "sb_publishable_oYTGDsHQOvboNc48dRfJTQ_0RqwlP7l",
      "eas": {
        "projectId": "5a760138-e5e8-4b0d-b23d-09840184d9d2"
      }
    }
  }
}
