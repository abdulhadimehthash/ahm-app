{
  "expo": {
    "name": "AHM",
    "slug": "ahm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ahm.mobile",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "AHM sends local reminders for tasks due today or tomorrow."
      }
    },
    "android": {
      "package": "com.ahm.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 21,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "AHM needs access to your photos to save documents.",
          "cameraPermission": "AHM needs access to your camera to take document photos."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "AHM needs access to your contacts to import them as a backup."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TaskWidget",
              "label": "AHM Tasks",
              "description": "Shows your most urgent task",
              "minWidth": "250dp",
              "minHeight": "40dp",
              "targetCellWidth": 4,
              "targetCellHeight": 1,
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/icon.png"
            }
          ]
        }
      ],
      "./plugins/withAbiFilters",
      "expo-font"
    ],
    "extra": {
      "supabaseUrl": "https://titiljrgqynroxpaznkq.supabase.co",
      "supabasePublishableKey": "sb_publishable_oYTGDsHQOvboNc48dRfJTQ_0RqwlP7l",
      "eas": {
        "projectId": "8de0ab64-a4b4-4820-8952-d126b9d69c8d"
      }
    },
    "owner": "nearbi"
  }
}
